{ lib, pkgs, ... }:
{
  environment.sessionVariables = {
    GST_PLUGIN_PATH = lib.makeSearchPathOutput "lib" "lib/gstreamer-1.0" (
      with pkgs.gst_all_1;
      [
        gstreamer
        gst-plugins-base
        gst-plugins-good
        gst-plugins-bad
        gst-plugins-ugly
      ]
    );
  };
  environment = {
    systemPackages = with pkgs; [
      warp-terminal
      filen-cli
      filen-desktop
      ente-cli
      ente-desktop
      proton-pass
      protonmail-export
      proton-authenticator
      protonmail-desktop
      clang-analyzer
      clang
      zed-editor
      brave
      cachix
      autorandr
      killall
      libnotify
      openssl
    ];
  };
}
